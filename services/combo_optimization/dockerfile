# ──────────────────────────────────────────────
#  Conut Combo Optimization Service  |  Port 8003
# ──────────────────────────────────────────────
FROM python:3.11.7-slim

WORKDIR /app

# 1. Install system build tools for C-extensions
RUN apt-get update && apt-get install -y gcc python3-dev && rm -rf /var/lib/apt/lists/*

# 2. Install dependencies
COPY services/combo_optimization/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# 3. Copy service source code
COPY services/combo_optimization/ .

# The API requires combo_results.json and ai_combo_pricing_results.csv
# These are generated by the pipeline scripts. If they are pre-built,
# they will be copied above. Otherwise run the pipeline at startup:
# CMD ["sh", "-c", "python price_parser.py && python basket_parser.py && python combo_analysis.py && python generate_combos.py && uvicorn api:app --host 0.0.0.0 --port 8003"]

EXPOSE 8003

CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8003"]