# ──────────────────────────────────────────────
#  Conut Growth Strategy Service  |  Port 8005
# ──────────────────────────────────────────────
FROM python:3.11.7-slim

WORKDIR /app

# 1. Install system build tools for C-extensions (like psutil)
RUN apt-get update && apt-get install -y gcc python3-dev && rm -rf /var/lib/apt/lists/*

# 2. Install dependencies
COPY services/growth/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# 3. Copy service source code
COPY services/growth/ .

EXPOSE 8005

CMD ["uvicorn", "api:app", "--host", "0.0.0.0", "--port", "8005"]